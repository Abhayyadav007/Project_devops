DATABASE_URL=postgresql://postgres:password123@localhost:5432/newdb
JWT_SECRET=123123
ROOT_VALIDATOR_ID=10001
ROOT_VALIDATOR_NAME=Root Validator
ROOT_VALIDATOR_EMAIL=root.validator@example.com
ROOT_VALIDATOR_PASSWORD=Validator@123

# If Postgres is not running yet, you can skip the seed so `pnpm dev` still starts this process
# (API calls will still fail until the database is up). Omit or set to false in normal use.
# SKIP_ROOT_VALIDATOR_SEED=true

# Set to "false" to skip automatic CREATE DATABASE for the DB name in DATABASE_URL
# AUTO_CREATE_DATABASE=false

# Set to "true" to skip `prisma migrate deploy` on HTTP backend startup (not recommended for fresh DBs)
# SKIP_PRISMA_MIGRATE_ON_START=true
